37814>>>        Get GetNavigateData to NavigateData
37815>>>        Get HasRecord of hoDD to bHasRecord
37816>>>
37816>>>        // Ocultamos todos los botones
37816>>>        WebSet pbRender of oEditBtn to False
37817>>>        WebSet pbRender of oSaveBtn to False
37818>>>        WebSet pbRender of oCancelChangesBtn to False
37819>>>        WebSet pbRender of oDeleteBtn to False
37820>>>
37820>>>        // Mostramos los que correspondan
37820>>>        If (NavigateData.bReadOnly) Begin
37822>>>            WebSet pbRender of oEditBtn to True
37823>>>        End
37823>>>>
37823>>>        Else Begin
37824>>>            WebSet pbRender of oSaveBtn to True
37825>>>            WebSet pbRender of oCancelChangesBtn to True
37826>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37827>>>        End
37827>>>>
37827>>>    End_Procedure
