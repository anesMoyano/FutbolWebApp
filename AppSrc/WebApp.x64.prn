38137>>>>>Class cjugadorDataDictionary is a DataDictionary
38138>>>>>    
38138>>>>>    Procedure Construct_Object
38140>>>>>        Forward Send Construct_Object
38142>>>>>        Set Main_File to jugador.File_Number  // Este DD controla la tabla JUGADOR
38143>>>>>
38143>>>>>        Set Add_Server_File to equipo.File_Number 
38144>>>>>        
38144>>>>>        // Esto indica que EQUIPO es la tabla padre de JUGADOR
38144>>>>>        // Relación: Equipo.ID = Jugador.EquipoID
38144>>>>>
38144>>>>>        Set Foreign_Field_Option DD_KEYFIELD DD_NOPUT to True
38145>>>>>        Set Foreign_Field_Option DD_KEYFIELD DD_FINDREQ to True
38146>>>>>        Set Foreign_Field_Option DD_INDEXFIELD DD_NOPUT to True
38147>>>>>        Set Foreign_Field_Option DD_DEFAULT DD_DISPLAYONLY to True
38148>>>>>        
38148>>>>>        Set Field_Value_Table Field jugador.Nacionalidad to oNacionalidadValidation 
38149>>>>>        //Asocia la tabla de validación creada antes al campo Nacionalidad del jugador.
38149>>>>>
38149>>>>>    End_Procedure
38150>>>>>
38150>>>>>End_Class
