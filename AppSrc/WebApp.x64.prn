38269>>>    // Control de visibilidad de botones según el modo (lectura/edición)
38269>>>    Procedure SetActionButtons
38272>>>        tWebNavigateData NavigateData
38272>>>        tWebNavigateData NavigateData
38272>>>        Boolean bHasRecord
38272>>>        Handle hoDD
38272>>>
38272>>>        Get Server to hoDD
38273>>>        Get GetNavigateData to NavigateData
38274>>>        Get HasRecord of hoDD to bHasRecord
38275>>>
38275>>>        // Ocultamos todos los botones
38275>>>        WebSet pbRender of oEditBtn to False
38276>>>        WebSet pbRender of oSaveBtn to False
38277>>>        WebSet pbRender of oCancelChangesBtn to False
38278>>>        WebSet pbRender of oDeleteBtn to False
38279>>>
38279>>>        // Mostramos los que correspondan
38279>>>        If (NavigateData.bReadOnly) Begin
38281>>>            WebSet pbRender of oEditBtn to True
38282>>>        End
38282>>>>
38282>>>        Else Begin
38283>>>            WebSet pbRender of oSaveBtn to True
38284>>>            WebSet pbRender of oCancelChangesBtn to True
38285>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38286>>>        End
38286>>>>
38286>>>    End_Procedure
