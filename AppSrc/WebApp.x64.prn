38300>>>        
38300>>>        Case Begin
38300>>>            Case (NavigateData.eNavigateType = nfFromMain)
38302>>>                // Navegación desde SelectLiga
38302>>>                Case Break
38303>>>
38303>>>            Case (NavigateData.eNavigateType = nfFromParent)
38306>>>                // Navegación desde vista padre
38306>>>                Case Break
38307>>>
38307>>>            Case (NavigateData.eNavigateType = nfFromChild)
38310>>>                // Navegación desde vista hija
38310>>>                Case Break
38311>>>
38311>>>            Case Else
38311>>>                // Otros casos
38311>>>        Case End
38311>>>       
38311>>>        Send SetActionButtons
38312>>>    End_Procedure
